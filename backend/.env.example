# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Database
DATABASE_URL=postgresql://pm:secret@postgres:5432/photomanager

# Redis
REDIS_URL=redis://redis:6379

# JWT (generera med: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Media paths (mappas via Docker volumes)
MEDIA_PHOTOS_PATH=/media/photos
MEDIA_THUMBS_PATH=/media/thumbs
MEDIA_TRANSCODE_PATH=/media/transcode

# Web Push (generera med: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com

# Papperskorg: antal dagar innan automatisk rensning
TRASH_AUTO_CLEAN_DAYS=30

# AI-modeller (valfritt — ansiktsigenkänning inaktiveras om filer saknas)
# Ladda ner från: https://github.com/deepinsight/insightface (model zoo: buffalo_l)
AI_DETECTOR_PATH=/models/SCRFD_500M_bnkps_shape640x640.onnx
AI_RECOGNIZER_PATH=/models/w600k_r50.onnx
