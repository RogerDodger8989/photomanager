# Lokal utvecklingskonfiguration — kopiera till .env för att testa utan Docker

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Sätt till din lokala PostgreSQL (t.ex. via Docker: docker run -p 5432:5432 ...)
DATABASE_URL=postgresql://pm:secret@localhost:5432/photomanager

# Redis (t.ex. via Docker: docker run -p 6379:6379 redis:7-alpine)
REDIS_URL=redis://localhost:6379

# JWT — byt ut mot valfri lång sträng
JWT_SECRET=dev_secret_minimum_32_tecken_lang_string_123
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Media — lokala testmappar (skapas automatiskt om de inte finns)
MEDIA_PHOTOS_PATH=./media/photos
MEDIA_THUMBS_PATH=./media/thumbs
MEDIA_TRANSCODE_PATH=./media/transcode

# Valfritt (AI-modeller)
# AI_DETECTOR_PATH=./models/SCRFD_500M_bnkps_shape640x640.onnx
# AI_RECOGNIZER_PATH=./models/w600k_r50.onnx

TRASH_AUTO_CLEAN_DAYS=30
